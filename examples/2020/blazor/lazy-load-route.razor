@* Lazy-load an assembly only when the user navigates to this route.
   Router configuration points LazyLoadedAssemblies at the .dll.
   The OnNavigateAsync callback shows a spinner while the assembly downloads. *@
@page "/reports"
@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(Program).Assembly"
        AdditionalAssemblies="@lazyLoadedAssemblies"
        OnNavigateAsync="@OnNavigateAsync">
    <Found Context="routeData">
        @if (isLoading)
        {
            <p>Loading...</p>
        }
        else
        {
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        }
    </Found>
</Router>

@code {
    private List<System.Reflection.Assembly> lazyLoadedAssemblies = new();
    private bool isLoading;

    [Inject] private Microsoft.AspNetCore.Components.WebAssembly.Services.LazyAssemblyLoader Loader { get; set; }

    private async Task OnNavigateAsync(NavigationContext ctx)
    {
        if (ctx.Path.StartsWith("reports"))
        {
            isLoading = true;
            var asm = await Loader.LoadAssembliesAsync(new[] { "Reports.dll" });
            lazyLoadedAssemblies.AddRange(asm);
            isLoading = false;
        }
    }
}
